# Mnemos environment template. Copy to .env and fill in.
# Secrets belong here; never commit the filled-in .env.

# -----------------------------------------------------------------------------
# GitHub App
# -----------------------------------------------------------------------------
# Created at https://github.com/settings/apps. Webhook URL should point at
# http://<your-host>:3000/api/github/webhooks.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# Used by the orchestrator's agents. Override ANTHROPIC_BASE_URL to route
# calls at a self-hosted, OpenAI-compatible model if you cannot send code to
# the public API.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
# Voyage is used for code embeddings, OpenAI for prose (PR bodies, ADRs).
# Both are optional; if unset, similarity features downgrade gracefully.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-code-3
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# -----------------------------------------------------------------------------
# Service internals
# -----------------------------------------------------------------------------
# Bearer secret shared between the TypeScript GitHub App service and the
# Python orchestrator. Never leaves the compose network.
INTERNAL_SECRET=
# URL the TypeScript service uses to reach the Python orchestrator. In docker
# compose this is the Python API service DNS name.
ORCHESTRATOR_URL=http://python-api:8000
# Base URL the orchestrator uses to build callback URLs delivered back to the
# TS service. In docker compose this is typically http://github-app:3001.
BASE_URL=http://github-app:3001

# -----------------------------------------------------------------------------
# Database and queue
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://mnemos:mnemos@postgres:5432/mnemos
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# Set to export OpenTelemetry traces; leave unset to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Prometheus endpoint is always on at /metrics. This only gates scrape auth.
METRICS_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Indexing tunables
# -----------------------------------------------------------------------------
# How far back the initial index walks. 1000 commits OR 12 months, whichever
# comes first.
INDEX_MAX_COMMITS=1000
INDEX_MAX_MONTHS=12
# Per-PR budget guardrails. See docs/architecture.md "LLM usage and cost control".
PER_PR_INPUT_TOKEN_CAP=200000
PER_PR_OUTPUT_TOKEN_CAP=20000
